  "keyFeatures": [
    "Visual Discord message editor with real-time preview",
    "Scheduled and recurring message automation",
    "Team collaboration with granular permissions",
    "Reusable message templates with dynamic variables",
    "AI-powered content generation (OpenAI/Gemini)",
    "Advanced webhook management and validation",
    "Comprehensive message history and analytics",
    "Admin dashboard for platform management"
  ],
  "publicApiSurface": [
    "POST /webhooks/validate - Validate Discord webhook URL",
    "POST /webhooks/{webhook}/send - Send message to webhook",
    "POST /send/temporary - Send to temporary webhook without saving",
    "GET /webhooks/{webhook}/history - Get message history",
    "POST /scheduled - Create scheduled message",
    "POST /scheduled/{scheduled}/pause - Pause scheduled message",
    "POST /scheduled/{scheduled}/resume - Resume scheduled message",
    "POST /templates - Create message template",
    "POST /templates/{template}/duplicate - Duplicate template",
    "POST /ai/generate - Generate content with AI",
    "POST /webhooks/{webhook}/collaborators - Invite collaborator",
    "POST /invitations/{token}/accept - Accept invitation",
    "GET /admin/scheduled-messages - Admin view all scheduled messages"
  ]
}
